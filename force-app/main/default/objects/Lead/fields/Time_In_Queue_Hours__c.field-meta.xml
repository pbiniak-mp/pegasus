<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Time_In_Queue_Hours__c</fullName>
    <externalId>false</externalId>
    <formula>IF(
    Owner:User.Id != null,
    (Accepted_Date__c - CreatedDate) * 24,
    (NOW() - CreatedDate) * 24
  )</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Time In Queue Hours</label>
    <precision>18</precision>
    <required>false</required>
    <scale>1</scale>
    <type>Number</type>
    <unique>false</unique>
</CustomField>
