<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Validate_Positive_Parapet_Width_in</fullName>
    <active>true</active>
    <errorConditionFormula>AND(NOT(ISBLANK(Parapet_Width_in__c)), Parapet_Width_in__c &lt;= 0)</errorConditionFormula>
    <errorDisplayField>Parapet_Width_in__c</errorDisplayField>
    <errorMessage>Parapet Width must be greater than 0. Leave blank if not applicable.</errorMessage>
</ValidationRule>
