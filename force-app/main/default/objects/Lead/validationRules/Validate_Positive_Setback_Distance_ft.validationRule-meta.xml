<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Validate_Positive_Setback_Distance_ft</fullName>
    <active>true</active>
    <errorConditionFormula>AND(NOT(ISBLANK(Setback_Distance_ft__c)), Setback_Distance_ft__c &lt;= 0)</errorConditionFormula>
    <errorDisplayField>Setback_Distance_ft__c</errorDisplayField>
    <errorMessage>Setback Distance must be greater than 0. Leave blank if not applicable.</errorMessage>
</ValidationRule>
