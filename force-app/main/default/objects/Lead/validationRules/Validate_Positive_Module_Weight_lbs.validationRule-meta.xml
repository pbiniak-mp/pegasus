<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Validate_Positive_Module_Weight_lbs</fullName>
    <active>true</active>
    <errorConditionFormula>AND(NOT(ISBLANK(Module_Weight_lbs__c)), Module_Weight_lbs__c &lt;= 0)</errorConditionFormula>
    <errorDisplayField>Module_Weight_lbs__c</errorDisplayField>
    <errorMessage>Module Weight must be greater than 0. Leave blank if not applicable.</errorMessage>
</ValidationRule>
